# =============================================================================
# SECURITY NOTE
# =============================================================================
# Copy this to .env.local:
#   cp frontend/.env.local.example frontend/.env.local
# NEVER commit .env.local to git.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser — do not put
# secrets in NEXT_PUBLIC_ variables.
# =============================================================================

# =============================================================================
# API CONFIGURATION
# =============================================================================
# URL of the NestJS backend API.
# NEXT_PUBLIC_ prefix makes this available in browser JavaScript.
# For development, Next.js rewrites proxy this (see next.config.ts),
# so the browser never directly calls this URL.
NEXT_PUBLIC_API_URL=http://localhost:4000/api
