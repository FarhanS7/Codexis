# =============================================================================
# SECURITY NOTE
# =============================================================================
# This file documents required environment variables. Copy it to .env:
#   cp backend/.env.example backend/.env
# Then fill in the real values. NEVER commit .env to git.
# =============================================================================

# =============================================================================
# APPLICATION
# =============================================================================
PORT=4000
NODE_ENV=development

# =============================================================================
# DATABASE
# =============================================================================
# Choose ONE of the three provider options below.
# Uncomment the block for your chosen provider and comment the others.
#
# HOW TO SWITCH PROVIDERS:
#   1. Comment out your current DATABASE_URL and DATABASE_DIRECT_URL
#   2. Uncomment the provider block you want to use
#   3. Restart the backend (npm run dev:backend)
#   4. Run `npx prisma migrate dev` to apply migrations to the new DB
# =============================================================================

# --- OPTION A: Docker (local, offline-capable) --------------------------------
# Requirements: Docker Desktop running, `npm run db:start` executed
# Pros: No internet, zero latency, free, data stays local
# Cons: Docker must be running
DATABASE_URL=postgresql://postgres:changeme_in_production@localhost:5432/ai_code_reviewer
DATABASE_DIRECT_URL=postgresql://postgres:changeme_in_production@localhost:5432/ai_code_reviewer
# Both URLs are identical for Docker — no pooler in the middle

# --- OPTION B: NeonDB (cloud, no Docker needed) --------------------------------
# Requirements: Free account at https://neon.tech
# Setup:
#   1. Create a project at neon.tech
#   2. Copy the connection strings from "Connection Details" panel
#   3. You will see two strings: "Pooled connection" and "Direct connection"
#      Pooled  = DATABASE_URL (for runtime queries)
#      Direct  = DATABASE_DIRECT_URL (for migrations)
# Pros: Free 512MB, no Docker, serverless-friendly, DB branching available
# Cons: Requires internet, slight latency vs local
#
# DATABASE_URL=postgresql://user:password@ep-xxx-yyy-zzz.us-east-2.aws.neon.tech/neondb?sslmode=require
# DATABASE_DIRECT_URL=postgresql://user:password@ep-xxx-yyy-zzz.us-east-2.aws.neon.tech/neondb?sslmode=require
# Note: For NeonDB free tier, both URLs may look the same.
# The difference appears when using Neon's connection pooler ("pooler" subdomain):
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
# DATABASE_DIRECT_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# --- OPTION C: Supabase (cloud, no Docker needed) ------------------------------
# Requirements: Free account at https://supabase.com
# Setup:
#   1. Create a project at app.supabase.com
#   2. Go to: Project Settings > Database > Connection string
#   3. DATABASE_URL     = "Transaction" pooler (port 6543) — for runtime
#   4. DATABASE_DIRECT_URL = "Direct connection" (port 5432) — for migrations
# Pros: Free 500MB, no Docker, includes dashboard for DB inspection
# Cons: Requires internet, PgBouncer pooler needs directUrl for migrations
#
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# DATABASE_DIRECT_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# IMPORTANT: Use port 6543 (pooler) for DATABASE_URL, port 5432 (direct) for DATABASE_DIRECT_URL
# Failing to do this will cause: "prepared statement does not exist" errors in Prisma

# =============================================================================
# AUTHENTICATION — GitHub OAuth
# =============================================================================
# Create a GitHub OAuth App at: https://github.com/settings/developers
# App settings:
#   Homepage URL: http://localhost:3000
#   Authorization callback URL: http://localhost:4000/api/auth/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/callback

# =============================================================================
# AUTHENTICATION — JWT
# =============================================================================
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# IMPORTANT: This secret signs JWT tokens. Changing it invalidates all existing sessions.
JWT_SECRET=generate_a_strong_64_char_hex_secret_here
JWT_EXPIRES_IN=7d

# =============================================================================
# SECURITY — Token Encryption
# =============================================================================
# AES-256-GCM key for encrypting GitHub access tokens at rest.
# Must be exactly 32 bytes (64 hex characters).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=generate_a_64_char_hex_key_here

# =============================================================================
# LLM PROVIDER
# =============================================================================
# OpenAI API key — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
# Default model to use. Users can override per-review via frontend settings.
DEFAULT_LLM_MODEL=gpt-4o

# Anthropic (optional — for model switcher in Task 9.2)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# =============================================================================
# GITHUB WEBHOOKS (Task 8.1)
# =============================================================================
# Secret token used to verify webhook signatures from GitHub.
# Set this in your GitHub repo settings > Webhooks.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GITHUB_WEBHOOK_SECRET=generate_a_webhook_secret_here

# =============================================================================
# FRONTEND
# =============================================================================
FRONTEND_URL=http://localhost:3000
