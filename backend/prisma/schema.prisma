// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ReviewStatus {
  PENDING
  STREAMING
  COMPLETE
  ERROR
}

enum Severity {
  bug
  style
  security
  performance
}

// User authenticated via GitHub OAuth
// githubId is the immutable GitHub user ID — used as the unique key
// accessToken is stored encrypted with AES-256-GCM (see CryptoService)
model User {
  id          String   @id @default(cuid())
  githubId    String   @unique              // GitHub's numeric user ID (immutable)
  login       String                        // GitHub username (can change)
  avatarUrl   String?                       // GitHub avatar URL (nullable)
  accessToken String                        // AES-256-GCM encrypted GitHub OAuth token
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt           // Auto-updated on every save

  // Relations
  reviews     Review[]

  @@map("users")                            // Table name in Postgres
}

model PromptVersion {
  id                 String    @id @default(cuid())
  version            Int       @unique       // Monotonically increasing version number
  systemPrompt       String                  // System message sent to LLM
  userPromptTemplate String                  // User prompt with {{DIFF_CHUNK}} placeholder
  isActive           Boolean   @default(false)
  createdAt          DateTime  @default(now())

  // Relations
  reviews            Review[]

  @@map("prompt_versions")
}

model Review {
  id               String       @id @default(cuid())
  createdAt        DateTime     @default(now())
  status           ReviewStatus @default(PENDING)
  model            String                    // LLM model used (e.g., "gpt-4o")
  tokensUsed       Int          @default(0)  // Total tokens (input + output)
  estimatedCostUsd Float        @default(0)  // Estimated USD cost
  latencyMs        Int          @default(0)  // End-to-end latency in ms

  // Foreign keys
  userId           String
  prId             String
  promptVersionId  String

  // Relations
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  pullRequest      PullRequest   @relation(fields: [prId], references: [id], onDelete: Cascade)
  promptVersion    PromptVersion @relation(fields: [promptVersionId], references: [id])
  comments         ReviewComment[]

  @@map("reviews")
}

model ReviewComment {
  id          String   @id @default(cuid())
  filePath    String                         // File path the comment targets
  line        Int                            // Line number in the modified file
  severity    Severity                       // bug | style | security | performance
  body        String                         // Comment text / suggestion body
  accepted    Boolean  @default(false)       // User accepted this suggestion
  dismissed   Boolean  @default(false)       // User dismissed this suggestion
  postedToGh  Boolean  @default(false)       // Has been posted as a GitHub PR review comment
  reviewId    String

  // Relations
  review      Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("review_comments")
}

model Repository {
  id          String    @id @default(cuid())
  githubId    Int       @unique              // GitHub repo ID — unique index for upsert
  name        String                         // Repository name (e.g., "hello-world")
  owner       String                         // Repository owner (e.g., "octocat")
  createdAt   DateTime  @default(now())

  // Relations
  pullRequests PullRequest[]

  @@map("repositories")
}

model PullRequest {
  id          String    @id @default(cuid())
  number      Int                            // PR number (e.g., 42)
  title       String                         // PR title
  headSha     String                         // Latest commit SHA (updated on synchronize)
  status      String    @default("open")     // "open" | "closed" | "merged"
  repoId      String
  createdAt   DateTime  @default(now())

  // Relations
  repository  Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)
  reviews     Review[]

  @@unique([repoId, number])                 // Composite unique for upsert
  @@map("pull_requests")
}
